generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum PlayerRole {
  BATSMAN
  BOWLER
  ALL_ROUNDER
}

enum ExtraType {
  NONE
  WIDE
  NO_BALL
}

enum WicketType {
  BOWLED
  CAUGHT
  RUN_OUT
  LBW
  STUMPED
  HIT_WICKET
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id            Int     @id @default(autoincrement())
  fullName      String
  email         String  @unique
  password      String
  mobileNumber  String?
  address       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////

model Team {
  id        Int      @id @default(autoincrement())
  name      String

  players   Player[]
  team1Matches Match[] @relation("Team1")
  team2Matches Match[] @relation("Team2")
  tossWins Match[] @relation("TossWinner")

  inningsBatting  Inning[] @relation("BattingTeam")
  inningsBowling  Inning[] @relation("BowlingTeam")
}

//////////////////////////////////////////////////////

model Player {
  id        Int        @id @default(autoincrement())
  name      String
  role      PlayerRole

  teamId    Int
  team      Team       @relation(fields: [teamId], references: [id])

  battingBalls Ball[] @relation("Batsman")
  bowlingBalls Ball[] @relation("Bowler")

  overs     Over[]

  stats     PlayerMatchStats[]
}

//////////////////////////////////////////////////////

model Match {
  id          Int      @id @default(autoincrement())
  matchDate   DateTime
  venue       String

  team1Id     Int
  team2Id     Int
  tossWinnerId Int

  team1       Team @relation("Team1", fields: [team1Id], references: [id])
  team2       Team @relation("Team2", fields: [team2Id], references: [id])
  tossWinner  Team @relation("TossWinner", fields: [tossWinnerId], references: [id])

  innings     Inning[]

  stats       PlayerMatchStats[]

  createdAt   DateTime @default(now())
}

//////////////////////////////////////////////////////

model Inning {
  id              Int    @id @default(autoincrement())
  inningNumber    Int

  matchId         Int
  battingTeamId   Int
  bowlingTeamId   Int

  match           Match @relation(fields: [matchId], references: [id])

  battingTeam     Team  @relation("BattingTeam", fields: [battingTeamId], references: [id])
  bowlingTeam     Team  @relation("BowlingTeam", fields: [bowlingTeamId], references: [id])

  overs           Over[]
}

//////////////////////////////////////////////////////

model Over {
  id           Int   @id @default(autoincrement())
  overNumber   Int

  inningId     Int
  bowlerId     Int

  inning       Inning @relation(fields: [inningId], references: [id])
  bowler       Player @relation(fields: [bowlerId], references: [id])

  balls        Ball[]
}

//////////////////////////////////////////////////////

model Ball {
  id           Int    @id @default(autoincrement())

  overId       Int
  batsmanId    Int
  bowlerId     Int

  ballNumber   Int
  runsScored   Int
  extraType    ExtraType @default(NONE)
  extraRuns    Int       @default(0)

  isWicket     Boolean   @default(false)
  wicketType   WicketType?

  over         Over   @relation(fields: [overId], references: [id])
  batsman      Player @relation("Batsman", fields: [batsmanId], references: [id])
  bowler       Player @relation("Bowler", fields: [bowlerId], references: [id])

  createdAt    DateTime @default(now())
}

//////////////////////////////////////////////////////

model PlayerMatchStats {
  id             Int   @id @default(autoincrement())

  matchId        Int
  playerId       Int

  runsScored     Int    @default(0)
  ballsFaced     Int    @default(0)
  oversBowled    Float  @default(0)
  runsConceded   Int    @default(0)
  wicketsTaken   Int    @default(0)

  match          Match  @relation(fields: [matchId], references: [id])
  player         Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId]) // one stat per player per match
}
